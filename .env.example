SERVICE_NAME=ai-image-upscale-api
DATABASE_URL=sqlite:///./upscale.db
REDIS_URL=redis://localhost:6379/0
STORAGE_ROOT=./storage
ENQUEUE_JOBS=false
UPSCALE_PROCESS_INLINE=true
UPSCALE_FAITHFUL_BACKEND=stub
UPSCALE_REALISTIC_BACKEND=disabled
UPSCALE_REGION_DETECTOR_BACKEND=local
UPSCALE_REGION_DETECTOR_COMMAND=
UPSCALE_REGION_DETECTOR_TIMEOUT_SECONDS=30
UPSCALE_TESSERACT_COMMAND=tesseract
UPSCALE_LOGO_DETECTOR_BACKEND=local
UPSCALE_LOGO_DETECTOR_COMMAND=
MAX_UPLOAD_BYTES=20971520
UPSCALE_MAX_INPUT_PIXELS=12000000
REALESRGAN_EXECUTABLE=
REALESRGAN_MODEL_PATH=
REALESRGAN_MODEL=realesrgan-x4plus
REALESRGAN_TIMEOUT_SECONDS=300
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
